# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
DATABASE_URL=postgresql://convomem:password@localhost:5432/convomem_db

# ─── Qdrant Vector DB ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # only needed for Qdrant Cloud

# ─── Valkey / Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for: gpt-4o-mini (fact extraction) + text-embedding-3-small (vectors)
OPENAI_API_KEY=sk-...

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-different-min-32-chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * to allow all (not recommended in prod).
CORS_ORIGINS=http://localhost:3000

# ─── API URL (used in Swagger docs) ───────────────────────────────────────────
API_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info             # trace | debug | info | warn | error
