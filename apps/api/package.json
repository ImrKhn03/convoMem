{
  "name": "@convomem/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.52.0",
    "pg-boss": "^12.14.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "uuid": "^13.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^pg-boss$": "<rootDir>/__mocks__/pg-boss.js",
      "^uuid$": "<rootDir>/__mocks__/uuid.js"
    }
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
